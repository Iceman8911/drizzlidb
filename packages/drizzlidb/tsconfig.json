{
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"lib": ["ESNext", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"rootDir": "./src",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	},
	"exclude": ["node_modules", "dist"],
	"extends": "../../tsconfig.json",
	"include": ["src/**/*"]
}
