{
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "^1.3.13",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.6"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"module": "index.ts",
	"name": "drizzlidb",
	"packageManager": "bun@1.3.12",
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev": "turbo run dev --parallel",
		"format": "turbo run format",
		"lint": "turbo run lint",
		"prepare": "husky",
		"test": "turbo run test"
	},
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	]
}
